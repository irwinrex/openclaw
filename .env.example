# 🛡️ OpenClaw Environment Configuration

# --- API Keys & Authentication ---
# Get your Google API key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Gateway security token (required for dashboard/websocket access)
OPENCLAW_GATEWAY_TOKEN=your-secure-password-here

# --- Network Configuration ---
OPENCLAW_PORT=18789
OPENCLAW_WEB_PORT=18790
OLLAMA_PORT=11434

# --- Resource Management (Optional overrides) ---
# Ollama Memory (Recommended 14G for Gemma 4 8B)
OLLAMA_MEM_LIMIT=14G
OLLAMA_MEM_RESERVE=4G

# OpenClaw Memory
OPENCLAW_MEM_LIMIT=4G
OPENCLAW_MEM_RESERVE=512M

# --- Provider Configuration ---
# Use "http://ollama:11434" for internal container networking
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=ollama-local